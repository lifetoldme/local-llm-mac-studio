# =============================================================
# Models - GGUF files are large and should never be committed
# =============================================================
*.gguf
*.bin
*.safetensors
/opt/models/

# =============================================================
# Logs
# =============================================================
*.log
/var/log/llamacpp/

# =============================================================
# Docker volumes and runtime data
# =============================================================
docker/volumes/
docker/data/

# =============================================================
# Colima runtime files
# =============================================================
.colima/

# =============================================================
# macOS system files
# =============================================================
.DS_Store
.AppleDouble
.LSOverride
.__MACOSX

# Extended attribute leftovers (the macOS quarantine issue)
*.plist.xattr

# =============================================================
# Secrets and environment files
# Never commit API keys or tokens
# =============================================================
.env
.env.*
!.env.example
secrets/

# =============================================================
# Editor and IDE files
# =============================================================
.idea/
.vscode/
*.iml
*.iws
*.ipr

# =============================================================
# Python (if you add RAG scripts or tooling later)
# =============================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# =============================================================
# Node (if you add any JS tooling later)
# =============================================================
node_modules/
npm-debug.log*
searxng/uwsgi.ini
